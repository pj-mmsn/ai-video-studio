# ============================================
# AI Video Studio — 模型配置
# ============================================

# --- 通用 LLM（Stage1 剧本 + 小说家）---
# 推荐: Z.AI 的 deepseek-v4-pro（本项目同款）
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.z.ai
LLM_MODEL=deepseek-v4-pro

# 备选: DeepSeek 官方（如果你的 Key 是 DeepSeek 的）
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 也可用 OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Stage 2: 分镜师（图像生成模型）
IMAGE_API_KEY=sk-your-key-here
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=dall-e-3

# Stage 3: 摄像师（视频生成模型）
VIDEO_API_KEY=your-video-api-key
VIDEO_BASE_URL=https://api.openai.com/v1
VIDEO_MODEL=sora

# 通用 LLM（fallback）
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1

# AI 小说家 — 配置文件
# 复制此文件为 .env 并填入实际值

# ===== LLM 配置 =====
# API Key（DeepSeek、OpenAI 或兼容 API）
LLM_API_KEY=sk-your-key-here

# API Base URL（根据提供商选择）
# DeepSeek:   https://api.deepseek.com/anthropic   (支持 reasoning 模型)
# DeepSeek:   https://api.deepseek.com/v1           (OpenAI 兼容)
# OpenAI:     https://api.openai.com/v1
# Z.AI:       https://api.z.ai                      (支持 DeepSeek V4 Pro)
LLM_BASE_URL=https://api.deepseek.com/anthropic

# 模型名称
# deepseek-v4-pro / deepseek-chat / deepseek-reasoner / gpt-4o
LLM_MODEL=deepseek-v4-pro

# 轻量模型（用于简单任务）
LLM_MODEL_LIGHT=deepseek-v4-flash

# 生成参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ===== 图像生成（可选） =====
# IMAGE_API_KEY=sk-your-key-here
# IMAGE_BASE_URL=https://api.openai.com/v1
# IMAGE_MODEL=dall-e-3

# ===== 视频生成（可选） =====
# VIDEO_API_KEY=your-key-here
# VIDEO_BASE_URL=https://api.runwayml.com/v1
# VIDEO_MODEL=gen3

# ===== 输出目录 =====
# OUTPUT_DIR=output

# ============================================
# AI Video Studio — 三模型配置
# ============================================

# Stage 1: 导演（推理模型）—— 推荐 deepseek-v4-pro（本项目同款）
DIRECTOR_API_KEY=sk-your-key-here
DIRECTOR_BASE_URL=https://api.deepseek.com/v1
DIRECTOR_MODEL=deepseek-chat

# 也可用 Z.AI 的 deepseek-v4-pro（推理能力强，适合剧本创作）:
# DIRECTOR_BASE_URL=https://api.z.ai
# DIRECTOR_MODEL=deepseek-v4-pro

# Stage 2: 分镜师（图像生成模型）
IMAGE_API_KEY=sk-your-key-here
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=dall-e-3

# Stage 3: 摄像师（视频生成模型）
VIDEO_API_KEY=your-video-api-key
VIDEO_BASE_URL=https://api.openai.com/v1
VIDEO_MODEL=sora

# 通用 LLM（fallback）
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
